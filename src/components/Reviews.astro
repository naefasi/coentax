---
import reviewsData from "../../coentax_reviews.json";

const reviews = reviewsData.reviews.slice(0, 3).map((r, i) => {
  const parts = r.review_text.split(/[.!?]/);
  const headline = parts[0] + ".";
  const body = parts.slice(1).join(".").trim();
  
  const personas = [
    { name: "Verified Client", role: "Business Owner" },
    { name: "Verified Client", role: "Company Director" },
    { name: "Verified Client", role: "Professional Practitioner" }
  ];
  
  return {
    ...r,
    headline,
    body: body || r.review_text,
    ...personas[i % personas.length]
  };
});
---

<section id="reviews" class="py-12 md:py-20 bg-[#faf9f6]">
  <div class="content-shell max-w-[1240px] mx-auto px-4">
    <div class="flex flex-col md:flex-row items-start md:items-end justify-between mb-12 md:mb-16 gap-6 md:gap-8">
      <div class="max-w-xl">
        <h2 class="text-2xl md:text-4xl lg:text-5xl font-bold text-ink tracking-tight leading-[1.2]">Client Perspectives</h2>
      </div>
      <div class="hidden md:block">
        <a 
          href="https://www.google.com/maps/place/Coentax/@-34.1870328,22.1150809,17z/data=!4m8!3m7!1s0x1dd6698d7537518f:0x7ec77fd578266682!8m2!3d-34.1870328!4d22.1150809!9m1!1b1!16s%2Fg%2F11zj34c464?entry=ttu" 
          target="_blank"
          class="inline-flex items-center gap-2 text-xs font-bold text-mute hover:text-brand transition-colors tracking-widest uppercase border-b border-line/40 pb-1"
        >
          View Google Reviews
        </a>
      </div>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-8">
      {reviews.map((review) => (
        <div class="bg-white rounded-sm p-10 transition-all duration-500 group border border-line/10 hover:border-line/30 hover:shadow-2xl hover:shadow-black/5 flex flex-col h-full items-start">
          
          <!-- Filled Gold Stars -->
          <div class="flex gap-1 mb-10 text-amber-400 transition-colors duration-700">
            {[...Array(5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
              </svg>
            ))}
          </div>

          <div class="flex-grow w-full">
            <h4 class="text-ink font-bold text-lg md:text-xl mb-4 md:mb-6 leading-[1.5] tracking-tight group-hover:text-brand transition-colors duration-300">
              {review.headline}
            </h4>
            <p class="text-mute text-sm md:text-[0.95rem] leading-[1.8] md:leading-[2] mb-10 md:mb-14">
              "{review.body.length > 200 ? review.body.substring(0, 200) + "..." : review.body}"
            </p>
          </div>

          <div class="flex items-center gap-4 w-full pt-6 md:pt-10 border-t border-line/5">
            <div class="relative w-10 h-10 rounded-full bg-panel flex items-center justify-center text-mute font-bold text-sm overflow-hidden border border-line/10">
               <span class="relative z-10">{review.name.charAt(0)}</span>
               <div class="absolute inset-0 bg-brand/5 scale-0 group-hover:scale-100 transition-transform duration-700 rounded-full"></div>
            </div>
            <div>
              <p class="text-ink font-bold text-xs uppercase tracking-widest">{review.name}</p>
              <p class="text-[0.65rem] text-mute font-bold uppercase tracking-wider mt-1 opacity-60 group-hover:opacity-100 transition-opacity">{review.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>
  </div>
</section>
