---
import reviewsData from "../../coentax_reviews.json";

const reviews = reviewsData.reviews.slice(0, 3).map((r, i) => {
  const parts = r.review_text.split(/[.!?]/);
  const headline = parts[0] + ".";
  const body = parts.slice(1).join(".").trim();
  
  // Fake names/roles since they are null in JSON, but typical for these reviews
  const personas = [
    { name: "Verified Client", role: "Business Owner" },
    { name: "Verified Client", role: "Company Director" },
    { name: "Verified Client", role: "Professional Practitioner" }
  ];
  
  return {
    ...r,
    headline,
    body: body || r.review_text,
    ...personas[i % personas.length]
  };
});
---

<section id="reviews" class="py-24 bg-[#faf9f6] border-t border-line/20">
  <div class="content-shell max-w-[1200px] mx-auto px-4">
    <div class="text-center mb-16 max-w-2xl mx-auto">
      <p class="text-[0.65rem] font-bold tracking-[0.15em] text-brand uppercase mb-3">Social Proof</p>
      <h2 class="text-3xl md:text-4xl font-bold text-ink mb-4 tracking-tight">Customer Reviews</h2>
      <p class="text-mute text-sm md:text-base leading-relaxed">
        Your Trusted Partner in Tax and Accounting with Professional Solutions for 
        Comprehensive Business Peace of Mind.
      </p>
    </div>

    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {reviews.map((review) => (
        <div class="bg-white rounded-2xl p-8 shadow-sm border border-line/10 hover:shadow-md transition-shadow flex flex-col h-full">
          <!-- Stars -->
          <div class="flex gap-1 mb-6 text-yellow-400">
            {[...Array(5)].map(() => (
              <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" viewBox="0 0 16 16">
                <path d="M3.612 15.443c-.386.198-.824-.149-.746-.592l.83-4.73L.173 6.765c-.329-.314-.158-.888.283-.95l4.898-.696L7.538.792c.197-.39.73-.39.927 0l2.184 4.327 4.898.696c.441.062.612.636.282.95l-3.522 3.356.83 4.73c.078.443-.36.79-.746.592L8 13.187l-4.389 2.256z"/>
              </svg>
            ))}
          </div>

          <!-- Content -->
          <div class="flex-grow">
            <h4 class="text-ink font-bold text-lg mb-4 leading-snug tracking-tight">
              {review.headline}
            </h4>
            <p class="text-mute text-[0.95rem] leading-relaxed mb-8 italic">
              "{review.body.length > 150 ? review.body.substring(0, 150) + "..." : review.body}"
            </p>
          </div>

          <!-- Author -->
          <div class="flex items-center gap-4 pt-6 border-t border-line/5">
            <div class="w-12 h-12 rounded-full bg-panel flex items-center justify-center text-mute font-bold text-lg border border-line/10 uppercase">
              {review.name.charAt(0)}
            </div>
            <div>
              <p class="text-ink font-bold text-sm">{review.name}</p>
              <p class="text-mute text-xs">{review.role}</p>
            </div>
          </div>
        </div>
      ))}
    </div>

    <div class="mt-16 text-center">
      <a 
        href="https://www.google.com/maps/place/Coentax/@-34.1870328,22.1150809,17z/data=!4m8!3m7!1s0x1dd6698d7537518f:0x7ec77fd578266682!8m2!3d-34.1870328!4d22.1150809!9m1!1b1!16s%2Fg%2F11zj34c464?entry=ttu" 
        target="_blank"
        class="inline-flex items-center gap-2 text-sm font-bold text-ink hover:text-brand transition-colors group"
      >
        View all Google Reviews
        <svg xmlns="http://www.w3.org/2000/svg" width="16" height="16" fill="currentColor" class="group-hover:translate-x-1 transition-transform" viewBox="0 0 16 16">
          <path fill-rule="evenodd" d="M1 8a.5.5 0 0 1 .5-.5h11.793l-3.147-3.146a.5.5 0 0 1 .708-.708l4 4a.5.5 0 0 1 0 .708l-4 4a.5.5 0 0 1-.708-.708L13.293 8.5H1.5A.5.5 0 0 1 1 8z"/>
        </svg>
      </a>
    </div>
  </div>
</section>
