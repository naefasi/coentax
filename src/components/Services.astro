---
const services = [
  {
    category: "ADVISORY & REPORTING",
    title: "Monthly Compliance & Advisory",
    description: "Ongoing peace of mind with regular <span class='bg-[#ebeae8] px-1 py-[0.15rem] text-ink'>VAT submissions</span>, bookkeeping review, <span class='bg-[#ebeae8] px-1 py-[0.15rem] text-ink'>management reports</span>, and tax guidance.",
    icon: "/brand/service-advisory.png",
  },
  {
    category: "RECONSTRUCTION",
    title: "Cleanup Work",
    description: "Fixing past bookkeeping errors, <span class='bg-[#ebeae8] px-1 py-[0.15rem] text-ink'>VAT corrections</span>, rebuilding records from <span class='bg-[#ebeae8] px-1 py-[0.15rem] text-ink'>bank statements</span>, and audit preparation.",
    icon: "/brand/service-cleanup.png",
  },
  {
    category: "TAXATION",
    title: "Tax Services",
    description: "Complete handling of <span class='bg-[#ebeae8] px-1 py-[0.15rem] text-ink'>Personal income tax (ITR12)</span>, <span class='bg-[#ebeae8] px-1 py-[0.15rem] text-ink'>Provisional tax (IRP6)</span>, and <span class='bg-[#ebeae8] px-1 py-[0.15rem] text-ink'>Company tax (ITR14)</span>.",
    icon: "/brand/service-tax.png",
  },
  {
    category: "RESOLUTION",
    title: "SARS Problem Solving",
    description: "Resolving complex issues including <span class='bg-[#ebeae8] px-1 py-[0.15rem] text-ink'>Notice of Objections (NOO, ADR1)</span>, penalty disputes, and payment arrangements.",
    icon: "/brand/service-resolution.png",
  }
];
---

<section id="services" class="pt-10 md:pt-16 pb-12 md:pb-20 bg-[#faf9f6]">
  <div class="content-shell max-w-[1240px] mx-auto px-6 sm:px-4">
    <!-- Header & Video Split -->
    <div class="flex flex-col lg:flex-row items-start lg:items-center justify-between gap-12 md:gap-16 mb-16 md:mb-20">
      <div class="max-w-xl lg:max-w-2xl">
        <p class="text-[0.6rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-mute mb-4 uppercase opacity-60">Services</p>
        <h2 class="text-2xl md:text-5xl font-bold text-ink leading-[1.2] mb-8 tracking-tighter">
          Solving compliance risks and financial disorganization
        </h2>
        <p class="text-[0.95rem] md:text-lg text-mute leading-[1.8] max-w-lg">
          I help business owners stay compliant with SARS, fix messy financials, and improve cash flow through proper VAT structuring and monthly reporting.
        </p>
      </div>
      
      <div class="w-full lg:w-auto shrink-0">
        <video 
          src="/video.webm" 
          autoplay 
          loop 
          muted 
          playsinline 
          class="w-full max-w-[400px] lg:max-w-[500px] rounded-xl mix-blend-multiply opacity-90 mx-auto lg:mx-0 object-cover"
        ></video>
      </div>
    </div>

    <!-- Grid -->
    <div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-6">
      {services.map((service, index) => (
        <div class="service-card group bg-white rounded-sm p-8 md:p-10 transition-all duration-300 border border-line/10 hover:border-line/30 cursor-pointer flex flex-col items-start" data-index={index}>
          <div class="flex justify-between items-start w-full mb-8">
            <img src={service.icon} alt={service.title} class="w-10 h-10 md:w-12 md:h-12 mix-blend-multiply opacity-80 group-hover:opacity-100 transition-opacity" loading="lazy" />
            <div class="w-8 h-8 rounded-full bg-panel flex items-center justify-center text-mute group-hover:bg-brand group-hover:text-white transition-colors duration-300">
               <svg class="w-4 h-4 transition-transform duration-300 toggle-icon" fill="none" viewBox="0 0 24 24" stroke="currentColor">
                 <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M12 4v16m8-8H4" />
               </svg>
            </div>
          </div>
          
          <p class="text-[0.6rem] md:text-[0.65rem] font-bold tracking-[0.2em] text-mute mb-4 uppercase opacity-60">{service.category}</p>
          <h3 class="text-xl md:text-2xl font-bold text-ink mb-4 tracking-tight group-hover:text-brand transition-colors">{service.title}</h3>
          
          <div class="max-h-0 opacity-0 overflow-hidden transition-all duration-500 ease-in-out description-container w-full">
            <p class="text-[0.95rem] md:text-[1rem] text-mute leading-[1.8] pt-4 border-t border-line/5" set:html={service.description}></p>
          </div>
        </div>
      ))}

      <!-- Highlight CTA Card -->
      <div class="bg-brand rounded-sm p-8 md:p-10 text-white flex flex-col justify-between items-start md:col-span-2 lg:col-span-1 transition-all duration-300 group">
        <svg class="w-8 h-8 md:w-10 md:h-10 text-white/90 mb-8" fill="none" viewBox="0 0 24 24" stroke="currentColor">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M13 10V3L4 14h7v7l9-11h-7z" />
        </svg>
        <div>
          <h3 class="text-xl md:text-2xl font-bold mb-4 tracking-tight">Ready to get started?</h3>
          <p class="text-sm md:text-base text-white/70 leading-relaxed mb-10">
            Get in touch to learn how we can secure your financial framework and protect your cash flow.
          </p>
          <a href="#contact" class="inline-flex items-center gap-3 font-bold text-sm tracking-widest uppercase group-hover:gap-5 transition-all">
            Contact Us
            <svg class="h-4 w-4" fill="none" viewBox="0 0 24 24" stroke="currentColor">
              <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2.5" d="M14 5l7 7m0 0l-7 7m7-7H3" />
            </svg>
          </a>
        </div>
      </div>
    </div>
  </div>
</section>

<script>
  function initExpandableCards() {
    const cards = document.querySelectorAll('.service-card');
    
    cards.forEach(card => {
      card.addEventListener('click', () => {
        const container = card.querySelector('.description-container');
        const icon = card.querySelector('.toggle-icon');
        const isExpanded = container.style.maxHeight && container.style.maxHeight !== '0px';
        
        // Reset all other cards (optional, depends on if user wants accordion behavior)
        // cards.forEach(otherCard => {
        //   if (otherCard !== card) {
        //     otherCard.querySelector('.description-container').style.maxHeight = '0px';
        //     otherCard.querySelector('.description-container').style.opacity = '0';
        //     otherCard.querySelector('.toggle-icon').style.transform = 'rotate(0deg)';
        //   }
        // });

        if (isExpanded) {
          container.style.maxHeight = '0px';
          container.style.opacity = '0';
          icon.style.transform = 'rotate(0deg)';
        } else {
          container.style.maxHeight = container.scrollHeight + "px";
          container.style.opacity = '1';
          icon.style.transform = 'rotate(135deg)'; // Rotates + to look like X
        }
      });
    });
  }

  // Handle both initial load and view transitions
  initExpandableCards();
  document.addEventListener('astro:after-swap', initExpandableCards);
</script>
